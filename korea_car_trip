.arr{display:none;position:fixed;top:19vh;transform:translateY(-50%);width:44px;height:44px;border-radius:50%;background:rgba(0,0,0,.35);border:1px solid rgba(255,255,255,.12);align-items:center;justify-content:center;cursor:pointer;transition:all .2s;font-size:1rem;color:rgba(255,255,255,.5);z-index:15;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px)}
.arr:hover{background:rgba(0,0,0,.5);color:#fff}
.arr.l{left:.7rem}.arr.r{right:.7rem}
@media(min-width:768px){.arr{display:flex}}

/* Instagram-style tap zones – invisible, full height */
.tap-zone{position:fixed;top:0;bottom:50px;z-index:12;width:22%}
.tap-zone.left{left:0}
.tap-zone.right{right:0}

/* Title mode */
body.tm .hero{height:100vh;justify-content:center;align-items:center;text-align:center}
body.tm .hero-c{display:flex;flex-direction:column;align-items:center}
body.tm h1{font-size:2.2rem}
