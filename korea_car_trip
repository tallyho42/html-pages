/* Nav dots */
.nav{position:fixed;bottom:0;left:0;right:0;z-index:20;display:flex;align-items:center;justify-content:center;padding:.55rem 1rem .75rem;background:linear-gradient(0deg,rgba(0,0,0,.7) 60%,transparent)}
