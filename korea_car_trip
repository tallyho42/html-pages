  {main:'Bulguksa',alt:'Seokguram'},
  {main:'Jinhae_District',alt:'Changwon'},
  {main:'Busan',alt:'Haeundae'}
];

const imgCache={};
async function loadWikiImg(a){
  if(!a)return '';
  if(imgCache[a])return imgCache[a];
  try{
    const r=await fetch(`https://en.wikipedia.org/api/rest_v1/page/summary/${encodeURIComponent(a)}`);
    const d=await r.json();
    const u=d.originalimage?.source||d.thumbnail?.source||'';
    imgCache[a]=u;return u;
  }catch(e){return ''}
}

const bg=document.getElementById('bg'),bg2el=document.getElementById('bg2');
async function setBg(i){
  const w=WIKI_IMGS[i];if(!w)return;
  const u=await loadWikiImg(w.main);
  if(u){bg.classList.remove('loading');bg.style.backgroundImage=`url(${u})`}
  const u2=await loadWikiImg(w.alt);
  if(u2)bg2el.style.backgroundImage=`url(${u2})`;
  // Preload neighbors
  if(i+1<WIKI_IMGS.length){loadWikiImg(WIKI_IMGS[i+1].main);loadWikiImg(WIKI_IMGS[i+1].alt)}
  if(i-1>=0){loadWikiImg(WIKI_IMGS[i-1].main);loadWikiImg(WIKI_IMGS[i-1].alt)}
}

// Parallax on scroll
const panel=document.getElementById('panel');
panel.addEventListener('scroll',()=>{
  const s=panel.scrollTop;
  bg2el.style.opacity=Math.min(s/350,1);
  bg.style.backgroundPositionY=`${30+s*0.04}%`;
});

