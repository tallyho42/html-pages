.rt{font-size:.75rem;color:rgba(255,255,255,.4);margin-top:.7rem;line-height:1.7;text-align:center;text-shadow:0 1px 6px rgba(0,0,0,.4)}
.sh2{margin-top:1.3rem;font-size:.72rem;color:rgba(255,255,255,.35);letter-spacing:.06em;animation:p 2s ease infinite}
@keyframes p{0%,100%{opacity:.3}50%{opacity:.55}}

.photo-layer.loading{background:linear-gradient(135deg,#0f1a2e,#1a2d4a 50%,#0f3460)!important}
