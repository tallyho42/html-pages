// Wikipedia articles – FIXED: day 9 now uses Gyeongju_Historic_Areas (tumuli)
const WIKI_IMGS=[
  {main:'Gyeongju',alt:'Bulguksa'},
  {main:'Hwaseong_Fortress',alt:'Suwon'},
  {main:'Everland',alt:'Everland'},
  {main:'Jeonju_Hanok_Village',alt:'Jeonju'},
  {main:'Maisan',alt:'Hanji'},
  {main:'Suncheon_Bay',alt:'Suncheon'},
