<style>
*{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%;overflow:hidden;font-family:'DM Sans',sans-serif;background:#0a0a0a;color:#fff;-webkit-font-smoothing:antialiased}
body{min-height:100vh;min-height:-webkit-fill-available}

.photo-layer{position:fixed;inset:0;z-index:0;background-size:cover;background-position:center 30%;transition:opacity .6s}
.photo-layer::after{content:'';position:absolute;inset:0;background:linear-gradient(0deg,rgba(0,0,0,.92) 0%,rgba(0,0,0,.55) 30%,rgba(0,0,0,.2) 55%,rgba(0,0,0,.35) 100%)}
.photo-layer.loading{background:#111!important}

.photo-layer-2{position:fixed;inset:0;z-index:0;background-size:cover;background-position:center;opacity:0;transition:opacity .6s}
.photo-layer-2::after{content:'';position:absolute;inset:0;background:linear-gradient(0deg,rgba(0,0,0,.92) 0%,rgba(0,0,0,.5) 30%,rgba(0,0,0,.15) 65%,rgba(0,0,0,.3) 100%)}

/* Hero – reduced height: 38vh instead of 52vh */
.hero{position:fixed;top:0;left:0;right:0;height:38vh;z-index:2;display:flex;flex-direction:column;justify-content:flex-end;padding:0 1.5rem .8rem;pointer-events:none;user-select:none}
.hero-c{position:relative;z-index:2;max-width:560px}
.hero-c>*{transition:opacity .35s,transform .35s}
.hero-c.sw>*{opacity:0;transform:translateY(6px)}

.icon{font-size:2.2rem;line-height:1;margin-bottom:.2rem;filter:drop-shadow(0 4px 12px rgba(0,0,0,.6))}
.day-l{font-size:.6rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.55);margin-bottom:.08rem;text-shadow:0 1px 4px rgba(0,0,0,.8)}
h1{font-family:'Playfair Display',Georgia,serif;font-size:1.65rem;font-weight:700;line-height:1.12;text-shadow:0 2px 12px rgba(0,0,0,.8),0 0 40px rgba(0,0,0,.5)}
.hero-sub{font-family:'Playfair Display',serif;font-style:italic;font-size:.82rem;color:rgba(255,255,255,.7);margin-top:.1rem;text-shadow:0 1px 8px rgba(0,0,0,.7)}
@media(min-width:768px){.hero{padding:0 3rem 1rem}h1{font-size:2.1rem}.icon{font-size:2.6rem}}

/* Panel starts at 38vh */
.panel{position:fixed;top:38vh;left:0;right:0;bottom:0;z-index:5;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch;overscroll-behavior-y:contain}
.panel-i{min-height:100%;padding:0 1.5rem 5rem}
@media(min-width:768px){.panel-i{max-width:600px;padding:0 2rem 5rem}}
.panel-i{transition:opacity .3s;opacity:1}
.panel-i.sw{opacity:0}

.handle{display:flex;justify-content:center;padding:.5rem 0 .15rem;position:sticky;top:0;z-index:6}
.handle span{width:30px;height:3.5px;border-radius:2px;background:rgba(255,255,255,.22)}

.badges{display:flex;flex-wrap:wrap;gap:.3rem;margin-bottom:.6rem}
.badge{display:inline-flex;align-items:center;gap:.25rem;background:rgba(0,0,0,.35);border:1px solid rgba(255,255,255,.12);border-radius:100px;padding:.22rem .65rem;font-size:.68rem;font-weight:500;letter-spacing:.03em;color:rgba(255,255,255,.7);backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px)}

