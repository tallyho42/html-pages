.sh{font-size:.62rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-top:1.2rem;margin-bottom:.45rem;padding-top:.7rem;border-top:1px solid rgba(255,255,255,.08)}

.place{display:flex;gap:.7rem;padding:.6rem .4rem;border-bottom:1px solid rgba(255,255,255,.06);text-decoration:none;color:inherit;border-radius:8px;margin:0 -.4rem;padding-left:.4rem;padding-right:.4rem;transition:background .15s}
