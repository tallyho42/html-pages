const hc=document.getElementById('hc'),pc=document.getElementById('pc'),dotsC=document.getElementById('dots');
let cur=0;
D.forEach((_,i)=>{const d=document.createElement('button');d.className='dot'+(i===0?' on':'');d.onclick=()=>goTo(i);dotsC.appendChild(d)});
const dots=[...dotsC.children];

function render(i){
  const d=D[i];
  document.body.classList.toggle('tm',!!d.t);
  setBg(i);
  bg2el.style.opacity=0;
  bg.style.backgroundPositionY='30%';
  let hh=`<div class="icon">${d.icon}</div>`;
  if(d.day)hh+=`<div class="day-l">${d.day}</div>`;
  hh+=`<h1>${d.h}</h1>`;
  if(d.sub)hh+=`<div class="hero-sub">${d.sub}</div>`;
  if(d.t)hh+=`<div class="rt">${d.route}</div><div class="sh2">klikni vpravo →</div>`;
  hc.innerHTML=hh;
  if(d.t){pc.innerHTML='';return}
  let pp='<div class="badges">';
  if(d.drive)pp+=`<span class="badge">🚗 ${d.drive}</span>`;
  if(d.sleep)pp+=`<span class="badge">🛏️ ${d.sleep}</span>`;
  pp+=`</div><p class="body">${d.body}</p>`;
  if(d.places?.length){
    pp+='<div class="sh">📍 Kam se podíváme</div>';
    d.places.forEach(([ic,n,ds,u])=>{pp+=`<a class="place" href="${u}" target="_blank" rel="noopener"><div class="pi">${ic}</div><div class="pf"><div class="pn">${n}</div><div class="pd">${ds}</div></div><div class="pa">›</div></a>`});
  }
  if(d.tips?.length){
    pp+='<div class="sh">💡 Tipy</div>';
    d.tips.forEach(([w,n,t])=>{pp+=`<div class="tip"><div class="tw">${w}</div><div class="tt">${n?'<strong>'+n+'</strong> · ':''}${t}</div></div>`});
  }
  pc.innerHTML=pp;
  panel.scrollTop=0;
}

function goTo(n){
  if(n<0||n>=D.length||n===cur)return;
  hc.classList.add('sw');pc.classList.add('sw');
  setTimeout(()=>{cur=n;render(n);dots.forEach((d,i)=>d.classList.toggle('on',i===n));hc.classList.remove('sw');pc.classList.remove('sw')},220);
}
function go(dir){goTo(cur+dir)}
render(0);

// Keyboard
document.addEventListener('keydown',e=>{if(e.key==='ArrowRight')go(1);if(e.key==='ArrowLeft')go(-1)});

// Instagram-style tap zones
document.getElementById('tapL').addEventListener('click',()=>go(-1));
document.getElementById('tapR').addEventListener('click',()=>go(1));

// Swipe on BOTH hero AND panel (horizontal only)
let tx=0,ty=0,swiping=false;
function swipeStart(e){tx=e.touches[0].clientX;ty=e.touches[0].clientY;swiping=true}
function swipeEnd(e){
  if(!swiping)return;swiping=false;
  const dx=e.changedTouches[0].clientX-tx;
  const dy=e.changedTouches[0].clientY-ty;
  // Only trigger if horizontal swipe is dominant and big enough
  if(Math.abs(dx)>Math.abs(dy)*1.3 && Math.abs(dx)>45){
    go(dx<0?1:-1);
  }
}

// Hero swipe
const hero=document.getElementById('hero');
hero.style.pointerEvents='auto';
hero.addEventListener('touchstart',swipeStart,{passive:true});
hero.addEventListener('touchend',swipeEnd,{passive:true});

// Panel swipe – only trigger horizontal, let vertical scroll through
panel.addEventListener('touchstart',swipeStart,{passive:true});
panel.addEventListener('touchend',swipeEnd,{passive:true});
</script>
