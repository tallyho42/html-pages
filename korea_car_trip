.pd{font-size:.78rem;line-height:1.5;color:rgba(255,255,255,.5)}
.pa{color:rgba(255,255,255,.2);font-size:.75rem;align-self:center;flex-shrink:0}

.tip{display:flex;gap:.55rem;padding:.5rem .65rem;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.04);border-radius:10px;margin-bottom:.35rem}
